 #include "scheduler.h"
 
@@ -29,9 +28,10 @@
     return 1;
 }
 
-static void sys_exit_impl(int code) {
-    (void)code;
-    elf_process_exit();
+static void sys_exit_impl(syscall_regs_t* regs) {
