diff -ruN src_unzip/src/kernel/scheduler.h step4/src/kernel/scheduler.h
--- src_unzip/src/kernel/scheduler.h	2026-04-03 02:11:23.000000000 +0000
+++ step4/src/kernel/scheduler.h	2026-04-03 02:40:28.519076158 +0000
@@ -86,10 +86,10 @@
  *
  * Terminate the current scheduled task without returning to it.
  *
- * The scheduler removes the task from the run queue, marks it for
- * deferred destruction, and switches directly to the next runnable
- * task.  The actual process_destroy() happens later on a safe stack
- * inside the scheduler.
+ * The scheduler marks the current task ZOMBIE, removes it from the
+ * run queue, and switches directly to the next runnable task.
+ * The task is not destroyed here; a waiter or reaper running on a
+ * different stack is responsible for process_destroy().
  */
 void sched_exit_current(unsigned int esp);
 
diff -ruN src_unzip/src/kernel/syscall.c step4/src/kernel/syscall.c
--- src_unzip/src/kernel/syscall.c	2026-04-03 02:11:23.000000000 +0000
